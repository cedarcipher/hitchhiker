# Signal
SIGNAL_PHONE_NUMBER=+1234567890

# Grist — fill these in after Grist is running (see README step 7)
GRIST_API_KEY=
GRIST_DOC_ID=

# OIDC (Grist ↔ Dex) — generate secrets with: openssl rand -hex 32
GRIST_OIDC_IDP_CLIENT_SECRET=
GRIST_OIDC_IDP_ISSUER=
GRIST_OIDC_SP_HOST=
GRIST_SESSION_SECRET=

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW=60

# Encrypted storage mount point (optional, default: /mnt/hitchhiker)
# HITCHHIKER_ENCRYPTED_MOUNT=/mnt/hitchhiker

# Caddy ports (optional — override for rootless Docker, which can't bind below 1024)
# CADDY_HTTPS_PORT=8443
# CADDY_HTTP_PORT=8080
